---
// @hakari - <article> semantic card
// @higuruma - accessible links and images
interface Props {
  title: string;
  slug: string;
  description: string;
  categoria: string;
  calorias: number;
  tempoPreparo: number;
  proteinas: number;
  image: string;
  imageAlt: string;
  rating: number;
  featured?: boolean;
  priority?: boolean;
}

const {
  title, slug, categoria,
  calorias, tempoPreparo, proteinas,
  image, imageAlt, rating, featured = false, priority = false,
} = Astro.props;

const categoriaNomes: Record<string, string> = {
  'cafe-da-manha':      'Café da Manhã',
  'almoco-fit':         'Almoço Fit',
  'lanches-saudaveis':  'Lanches Saudáveis',
  'jantar-low-carb':    'Jantar Low Carb',
  'sobremesas-fit':     'Sobremesas Fit',
  'smoothies-e-sucos':  'Smoothies e Sucos',
  'pre-treino':         'Pré-Treino',
  'pos-treino':         'Pós-Treino',
};

const stars = '★'.repeat(Math.round(rating));
---

<article class={`recipe-card card-brutal ${featured ? 'recipe-card--featured' : ''}`}>
  <!-- Image -->
  <a
    href={`/receitas/${slug}/`}
    class="recipe-card__image"
    tabindex="-1"
    aria-hidden="true"
  >
    <img
      src={image}
      alt={imageAlt}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding={priority ? 'sync' : 'async'}
      width="400"
      height="300"
      sizes="(max-width: 640px) calc(100vw - 2rem), (max-width: 1024px) calc(50vw - 2.5rem), 400px"
    />
  </a>

  <!-- Body -->
  <div class="recipe-card__body">
    <!-- Category badge -->
    <span class="badge badge-secondary recipe-card__cat">
      {categoriaNomes[categoria]}
    </span>

    <!-- Title -->
    <h3 class="recipe-card__title">
      <a href={`/receitas/${slug}/`} class="recipe-card__title-link">
        {title}
      </a>
    </h3>

    <!-- Meta -->
    <div class="recipe-card__meta" aria-label="Informações rápidas">
      <span class="recipe-card__meta-item" title="Calorias">
        🔥 <span class="sr-only">Calorias:</span>{calorias} kcal
      </span>
      <span class="recipe-card__meta-item" title="Tempo de preparo">
        ⏱ <span class="sr-only">Tempo:</span>{tempoPreparo} min
      </span>
      <span class="recipe-card__meta-item" title="Proteínas">
        💪 <span class="sr-only">Proteínas:</span>{proteinas}g prot
      </span>
    </div>

    <!-- Rating -->
    <div class="recipe-card__rating" aria-label={`Avaliação: ${rating} estrelas`}>
      <span class="stars" aria-hidden="true">{stars}</span>
      <span class="rating-count">{rating}</span>
    </div>

    <!-- CTA -->
    <a href={`/receitas/${slug}/`} class="btn btn-primary recipe-card__btn">
      Ver Receita
    </a>
  </div>
</article>

<style>
  .recipe-card__cat { margin-bottom: var(--space-2); }

  .recipe-card__title-link {
    text-decoration: none;
    color: inherit;
    transition: color var(--transition);
  }
  .recipe-card__title-link:hover { color: var(--color-primary); }

  .recipe-card__rating { margin-top: auto; padding-top: var(--space-2); }

  .recipe-card__btn {
    margin-top: var(--space-3);
    width: 100%;
    justify-content: center;
  }

  .recipe-card--featured {
    border-color: var(--color-primary);
    border-width: 3px;
  }
  .recipe-card--featured .recipe-card__image::after {
    content: '⭐ Destaque';
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    background: var(--color-accent);
    color: var(--color-ink);
    font-size: var(--text-xs);
    font-weight: 700;
    padding: var(--space-1) var(--space-3);
    border: 2px solid var(--color-ink);
  }
  .recipe-card--featured .recipe-card__image {
    position: relative;
  }
</style>
