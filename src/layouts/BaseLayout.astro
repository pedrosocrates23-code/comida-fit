---
// @uraume - <head> precision crystallization
// @hakari  - semantic landmark structure
import '@styles/global.css';
import '@fontsource/fredoka-one/400.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/700.css';
import '@fontsource/space-mono/700.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/images/og-default.webp',
  imageAlt = 'Melhores Receitas Fit',
  canonicalUrl,
  type = 'website',
  schema,
  noindex = false,
} = Astro.props;

const siteUrl    = 'https://melhoresreceitasfit.com.br';
const siteName   = 'Melhores Receitas Fit';
const canonical  = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImage    = image.startsWith('http') ? image : `${siteUrl}${image}`;
const pageTitle  = title === siteName
  ? `${siteName}: Receitas Saudáveis e Fit`
  : `${title} | ${siteName}`;

const schemaArray = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : [];

// Organization schema always present
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/images/logo.svg`,
  sameAs: [],
};
schemaArray.push(orgSchema);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <!-- ── Charset & Viewport (URAUME: always first) ────── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Title ─────────────────────────────────────────── -->
    <title>{pageTitle}</title>

    <!-- ── Meta SEO ──────────────────────────────────────── -->
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    }
    <meta name="author" content={siteName} />
    <meta name="generator" content={Astro.generator} />

    <!-- ── Canonical ─────────────────────────────────────── -->
    <link rel="canonical" href={canonical} />

    <!-- ── Open Graph ────────────────────────────────────── -->
    <meta property="og:type"        content={type} />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:image:alt"   content={imageAlt} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale"      content="pt_BR" />

    <!-- ── Twitter / X Card ──────────────────────────────── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <meta name="twitter:image:alt"   content={imageAlt} />

    <!-- ── Favicon ───────────────────────────────────────── -->
    <link rel="icon"             href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- ── Sitemap ───────────────────────────────────────── -->
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- ── Fonts: self-hosted via @fontsource (zero external DNS) ── -->

    <!-- ── JSON-LD Schema (@uraume) ─────────────────────── -->
    {schemaArray.map((s) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- ── Slot para preloads e extras de página ─────────── -->
    <slot name="head" />

    <!-- ── Google Analytics 4 ────────────────────────────── -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MVZND1ZQG5" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MVZND1ZQG5');
    </script>
  </head>

  <body>
    <!-- ── Skip to content (@higuruma WCAG 2.2) ──────────── -->
    <a href="#main-content" class="skip-to-content">
      Ir para o conteúdo principal
    </a>

    <slot />
  </body>
</html>
