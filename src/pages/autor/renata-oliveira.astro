---
// Página de autora — E-E-A-T: Experience, Expertise, Authoritativeness, Trustworthiness
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Breadcrumb from '@components/Breadcrumb.astro';

const breadcrumbs = [
  { name: 'Home',          url: 'https://melhoresreceitasfit.com.br/' },
  { name: 'Sobre a Autora', url: 'https://melhoresreceitasfit.com.br/autor/renata-oliveira/' },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Renata Oliveira',
  url: 'https://melhoresreceitasfit.com.br/autor/renata-oliveira/',
  image: 'https://melhoresreceitasfit.com.br/images/renata-oliveira-autora.webp',
  jobTitle: 'Nutricionista e Criadora de Conteúdo',
  description: 'Nutricionista formada pela PUC Goiás, criadora do blog Melhores Receitas Fit, especializada em adaptações de receitas brasileiras tradicionais para versões fit e saudáveis.',
  alumniOf: {
    '@type': 'EducationalOrganization',
    name: 'PUC Goiás',
  },
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Graduação em Nutrição',
      credentialCategory: 'degree',
      recognizedBy: { '@type': 'Organization', name: 'PUC Goiás' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      name: 'Certificação em Nutrição Esportiva',
      credentialCategory: 'certificate',
      recognizedBy: { '@type': 'Organization', name: 'ACSM' },
    },
  ],
  knowsAbout: [
    'Nutrição',
    'Receitas Fit',
    'Reeducação Alimentar',
    'Nutrição Esportiva',
    'Gastronomia Funcional',
    'Low Carb',
    'Alimentação Saudável',
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'Melhores Receitas Fit',
    url: 'https://melhoresreceitasfit.com.br',
  },
  sameAs: [
    'https://www.instagram.com/melhoresreceitasfit',
  ],
};
---

<BaseLayout
  title="Renata Oliveira — Nutricionista e Criadora do Melhores Receitas Fit"
  description="Conheça Renata Oliveira, nutricionista formada pela PUC Goiás e criadora do Melhores Receitas Fit. Mais de 300 receitas saudáveis desenvolvidas com base em formação clínica e experiência prática."
  image="/images/renata-oliveira-autora.webp"
  imageAlt="Renata Oliveira, nutricionista e criadora do blog Melhores Receitas Fit"
  canonicalUrl="https://melhoresreceitasfit.com.br/autor/renata-oliveira/"
  type="article"
  schema={personSchema}
>
  <Header />

  <main id="main-content">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />

      <article class="autor-page" itemscope itemtype="https://schema.org/Person">
        <meta itemprop="name" content="Renata Oliveira" />
        <meta itemprop="url" content="https://melhoresreceitasfit.com.br/autor/renata-oliveira/" />

        <!-- Hero da autora -->
        <header class="autor-hero">
          <div class="autor-hero__photo-wrap">
            <img
              src="/images/renata-oliveira-autora.webp"
              alt="Renata Oliveira, nutricionista e criadora do Melhores Receitas Fit"
              width="600"
              height="700"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
              class="autor-hero__photo"
              itemprop="image"
            />
          </div>

          <div class="autor-hero__bio">
            <div class="autor-hero__badges">
              <span class="badge badge-primary">Nutricionista CRN-1</span>
              <span class="badge badge-secondary">PUC Goiás</span>
              <span class="badge badge-accent">ACSM Certified</span>
            </div>

            <h1 class="autor-hero__name" itemprop="name">Renata Oliveira</h1>
            <p class="autor-hero__title" itemprop="jobTitle">Nutricionista · Criadora do Melhores Receitas Fit</p>

            <p class="autor-hero__summary" itemprop="description">
              Renata Oliveira é nutricionista, cozinheira autodidata e criadora do blog Melhores Receitas Fit,
              onde compartilha receitas saudáveis desenvolvidas a partir de sua própria transformação alimentar
              iniciada no interior de Goiás. Com mais de 300 receitas publicadas, Renata combina ingredientes
              acessíveis com técnicas simples para provar que comida fit pode ter sabor de comida de verdade.
            </p>

            <div class="autor-hero__stats" role="list" aria-label="Conquistas de Renata Oliveira">
              <div class="autor-stat" role="listitem">
                <span class="autor-stat__number">300+</span>
                <span class="autor-stat__label">Receitas publicadas</span>
              </div>
              <div class="autor-stat" role="listitem">
                <span class="autor-stat__number">2M+</span>
                <span class="autor-stat__label">Visitas anuais</span>
              </div>
              <div class="autor-stat" role="listitem">
                <span class="autor-stat__number">180K</span>
                <span class="autor-stat__label">Seguidores Instagram</span>
              </div>
              <div class="autor-stat" role="listitem">
                <span class="autor-stat__number">8K+</span>
                <span class="autor-stat__label">E-books vendidos</span>
              </div>
            </div>
          </div>
        </header>

        <!-- Corpo do artigo -->
        <div class="autor-body">

          <h2>Quem é Renata Oliveira, a criadora do Melhores Receitas Fit?</h2>

          <p><strong>Renata Oliveira</strong> nasceu em <strong>Itumbiara, interior de Goiás</strong>, numa casa onde a cozinha era o centro de tudo. A avó, dona Carminha, acordava antes do sol para preparar o arroz com pequi, o frango caipira no fogão a lenha e o bolo de fubá que perfumava a rua inteira. Cada refeição era um ritual. A mesa sempre cheia, os pratos sempre fartos, o afeto sempre medido em colheradas generosas.</p>

          <p>Renata cresceu acreditando que comida boa era sinônimo de exagero. Repetia o prato sem pensar. Misturava o arroz com farofa e ainda pedia mais caldo. Na adolescência, quando a família se mudou para <strong>Goiânia</strong>, os hábitos pioraram. Lanchonetes, refrigerante no almoço, salgados da cantina. Aos <strong>22 anos</strong>, com <strong>97 quilos</strong> e um diagnóstico de <strong>resistência à insulina</strong>, ouviu do médico uma frase que mudou tudo: "Se você não mudar agora, vai depender de remédio pro resto da vida."</p>

          <p>O susto foi real. Mas o medo maior não era da doença. Era de perder a relação com a comida que a conectava à avó, à infância, ao cheiro de casa. Renata não queria viver de folha e peito de frango sem sal. Queria encontrar um caminho onde <strong>saúde e sabor</strong> pudessem coexistir sem que um anulasse o outro.</p>

          <h2>Como nasceu o blog Melhores Receitas Fit?</h2>

          <p>A transformação de Renata começou na própria cozinha, em <strong>2017</strong>, com um caderno de anotações e muita tentativa. Ela decidiu adaptar as receitas da avó usando ingredientes com menor carga glicêmica e maior valor nutricional. O primeiro experimento foi um <strong>bolo de fubá sem açúcar refinado</strong>, adoçado com banana madura e mel de abelha do cerrado. O resultado surpreendeu a família inteira. O sabor estava lá, intacto, com metade das calorias.</p>

          <p>Ela passou a registrar cada adaptação no celular, com foto e lista de ingredientes. Amigas começaram a pedir as receitas pelo WhatsApp. O volume de pedidos cresceu tanto que, em <strong>janeiro de 2019</strong>, Renata criou o blog <strong>Melhores Receitas Fit</strong> como um repositório organizado para compartilhar o que já fazia informalmente. Em menos de <strong>6 meses</strong>, o blog alcançou <strong>50 mil visitas mensais</strong> sem nenhum investimento em anúncios.</p>

          <p>O diferencial era claro: Renata não copiava receitas genéricas da internet. Cada publicação carregava uma história pessoal, um ingrediente regional e uma preocupação real com o bolso de quem lia. <strong>Farinha de mandioca no lugar de aveia importada. Pequi no molho proteico. Polvilho azedo na massa de pizza fit.</strong> O público se identificou porque a comida parecia possível, não aspiracional.</p>

          <h2>Qual é a formação e a experiência de Renata Oliveira?</h2>

          <p>Movida pela vontade de entender o que acontecia dentro do corpo a cada refeição, Renata ingressou no curso de <strong>Nutrição pela PUC Goiás</strong> em <strong>2018</strong>. Formou-se em <strong>2022</strong> com o trabalho de conclusão intitulado "Adaptações calóricas em receitas tradicionais do cerrado goiano: viabilidade nutricional e aceitação sensorial." O estudo avaliou <strong>12 receitas regionais</strong> adaptadas e comprovou que era possível reduzir até <strong>40% do valor calórico</strong> sem comprometer o sabor percebido pelos participantes.</p>

          <p>Durante a graduação, Renata estagiou em <strong>clínicas de reeducação alimentar</strong> e atuou como voluntária em projetos de <strong>educação nutricional</strong> em escolas públicas de Goiânia. Essa experiência moldou a linguagem do blog: acessível, sem jargão técnico desnecessário e sempre conectada à realidade financeira do público brasileiro.</p>

          <p>Após a formação, obteve certificação em <strong>Nutrição Esportiva pela ACSM</strong> e completou cursos de <strong>gastronomia funcional</strong> no Senac. A combinação entre conhecimento clínico e habilidade culinária é o que diferencia o conteúdo do Melhores Receitas Fit de blogs que apenas replicam tabelas nutricionais sem contexto prático.</p>

          <!-- Credenciais em destaque -->
          <div class="autor-credentials" role="list" aria-label="Formação e credenciais">
            <div class="autor-credential" role="listitem">
              <span class="autor-credential__icon" aria-hidden="true">🎓</span>
              <div>
                <strong>Nutrição — PUC Goiás</strong>
                <span>Graduação concluída em 2022</span>
              </div>
            </div>
            <div class="autor-credential" role="listitem">
              <span class="autor-credential__icon" aria-hidden="true">🏅</span>
              <div>
                <strong>Nutrição Esportiva — ACSM</strong>
                <span>Certificação complementar</span>
              </div>
            </div>
            <div class="autor-credential" role="listitem">
              <span class="autor-credential__icon" aria-hidden="true">🍳</span>
              <div>
                <strong>Gastronomia Funcional — Senac</strong>
                <span>Formação técnica em cozinha</span>
              </div>
            </div>
            <div class="autor-credential" role="listitem">
              <span class="autor-credential__icon" aria-hidden="true">📋</span>
              <div>
                <strong>Registro CRN-1 ativo</strong>
                <span>Conselho Regional de Nutrição</span>
              </div>
            </div>
          </div>

          <h2>O que Renata Oliveira conquistou com o Melhores Receitas Fit?</h2>

          <p>Os números contam parte da história. O blog acumula mais de <strong>300 receitas fit publicadas</strong>, com foco em café da manhã, almoço, lanches e sobremesas saudáveis. São mais de <strong>2 milhões de visitas anuais</strong>, concentradas em buscas orgânicas por termos como <strong>receitas fit fáceis</strong>, <strong>receitas saudáveis para emagrecer</strong> e <strong>receitas low carb brasileiras</strong>.</p>

          <p>Renata foi destaque em matérias sobre alimentação saudável em portais como <strong>VivaBem (UOL)</strong> e <strong>Minha Vida</strong>. Em <strong>2023</strong>, lançou o e-book "Fit com Sabor de Casa", que vendeu mais de <strong>8 mil cópias</strong> nos primeiros <strong>3 meses</strong>. O livro reúne <strong>60 receitas</strong> adaptadas de pratos clássicos brasileiros, com tabela nutricional completa e sugestões de substituição para restrições alimentares.</p>

          <p>Além do blog, Renata mantém uma comunidade ativa no Instagram com mais de <strong>180 mil seguidores</strong>, onde publica vídeos curtos de preparo e responde dúvidas sobre <strong>alimentação saudável</strong>, <strong>contagem de macros</strong> e <strong>reeducação alimentar</strong>. O engajamento médio das publicações supera <strong>4,5%</strong>, um indicador de audiência genuinamente envolvida com o conteúdo.</p>

          <h2>Qual é a filosofia por trás das receitas do blog?</h2>

          <p>Renata resume sua filosofia em uma frase que repete em todas as entrevistas: <strong>"Se não tem gosto de comida de verdade, não coloco no blog."</strong> Essa premissa orienta cada receita publicada. O ingrediente precisa ser encontrado em supermercado comum. O preparo não pode exigir mais de <strong>40 minutos</strong>. E o resultado final precisa agradar quem não está de dieta também.</p>

          <p>A abordagem rejeita a dicotomia entre <strong>comida saborosa e comida saudável</strong>. Para Renata, essa separação é uma construção cultural que afasta as pessoas da alimentação equilibrada. Quando alguém experimenta um <strong>brigadeiro fit feito com batata doce e cacau</strong> e não consegue distinguir do original, a barreira mental se dissolve. A mudança alimentar deixa de ser sacrifício e passa a ser escolha consciente.</p>

          <p>Cada receita do blog traz informação nutricional completa: <strong>calorias, proteínas, carboidratos, gorduras e fibras por porção</strong>. Renata também indica para quais objetivos a receita se adapta melhor, seja <strong>ganho de massa muscular</strong>, <strong>emagrecimento</strong>, <strong>controle glicêmico</strong> ou <strong>alimentação infantil saudável</strong>. Essa transparência nutricional é parte do compromisso editorial do Melhores Receitas Fit com a entrega de conteúdo confiável e verificável.</p>

          <h2>Por que confiar no conteúdo do Melhores Receitas Fit?</h2>

          <p>O blog opera sob critérios editoriais rígidos. Toda receita passa por <strong>3 etapas de validação</strong>: teste prático na cozinha, cálculo nutricional com base na <strong>Tabela TACO (Unicamp)</strong> e revisão de texto com verificação de dados. Renata não publica receitas que não tenha preparado pessoalmente ao menos <strong>duas vezes</strong>. Essa política elimina o problema comum em blogs de receitas que republicam conteúdo sem teste real.</p>

          <p>A formação acadêmica em <strong>Nutrição</strong>, registrada no <strong>CRN-1</strong>, garante respaldo técnico para as orientações nutricionais presentes nos textos. Quando o tema exige especialização fora do escopo de Renata, como <strong>alergias alimentares graves</strong> ou <strong>distúrbios metabólicos</strong>, o blog indica a consulta com profissional especializado. Essa postura editorial protege o leitor e reforça a credibilidade da publicação.</p>

          <p>O Melhores Receitas Fit não aceita publieditoriais disfarçados de receita. Parcerias comerciais são identificadas com selo de transparência. Produtos recomendados são testados por Renata antes de qualquer menção. Essa independência editorial é o que sustenta a confiança de uma audiência que retorna ao blog não por algoritmo, mas por experiência comprovada na própria cozinha.</p>

          <!-- FAQ estruturado -->
          <section class="autor-faq" aria-labelledby="faq-title">
            <h2 id="faq-title">Perguntas frequentes sobre Renata Oliveira</h2>

            <div class="faq-item" itemscope itemtype="https://schema.org/Question">
              <h3 itemprop="name">Renata Oliveira é nutricionista formada?</h3>
              <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text"><strong>Renata Oliveira</strong> é graduada em <strong>Nutrição pela PUC Goiás</strong>, com registro ativo no <strong>CRN-1</strong>. Possui certificação complementar em <strong>Nutrição Esportiva pela ACSM</strong> e formação em <strong>gastronomia funcional pelo Senac</strong>.</p>
              </div>
            </div>

            <div class="faq-item" itemscope itemtype="https://schema.org/Question">
              <h3 itemprop="name">Quantas receitas o blog Melhores Receitas Fit tem publicadas?</h3>
              <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text">O blog conta com mais de <strong>300 receitas fit</strong> organizadas por categoria: café da manhã, almoço, jantar, lanches e sobremesas. Cada publicação inclui <strong>tabela nutricional completa</strong> e tempo estimado de preparo.</p>
              </div>
            </div>

            <div class="faq-item" itemscope itemtype="https://schema.org/Question">
              <h3 itemprop="name">As receitas do blog usam ingredientes acessíveis?</h3>
              <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text">Todos os ingredientes podem ser encontrados em <strong>supermercados convencionais</strong>. Renata prioriza insumos brasileiros e regionais, como <strong>polvilho, mandioca, pequi e frutas do cerrado</strong>, evitando dependência de produtos importados.</p>
              </div>
            </div>

            <div class="faq-item" itemscope itemtype="https://schema.org/Question">
              <h3 itemprop="name">Renata Oliveira faz consultas nutricionais online?</h3>
              <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text">Renata atende em <strong>consultoria nutricional online</strong> com foco em <strong>reeducação alimentar e emagrecimento saudável</strong>. O agendamento é realizado pelo perfil oficial no Instagram ou pelo formulário de contato do blog.</p>
              </div>
            </div>

            <div class="faq-item" itemscope itemtype="https://schema.org/Question">
              <h3 itemprop="name">O blog Melhores Receitas Fit tem e-book disponível?</h3>
              <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text">O e-book <strong>"Fit com Sabor de Casa"</strong> reúne <strong>60 receitas</strong> adaptadas de pratos clássicos brasileiros, com tabela nutricional e sugestões de substituição. Está disponível para compra diretamente no site do blog.</p>
              </div>
            </div>
          </section>

          <!-- CTA — receitas -->
          <div class="autor-cta">
            <p>Explore as receitas desenvolvidas por Renata e experimente na sua cozinha:</p>
            <a href="/receitas/" class="autor-cta__btn">Ver todas as receitas</a>
          </div>

        </div>
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Layout geral ──────────────────────────────────────────── */
  .autor-page {
    padding-block: var(--space-8) var(--space-16);
  }

  /* ── Hero ──────────────────────────────────────────────────── */
  .autor-hero {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-12);
    align-items: start;
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: var(--border);
  }

  @media (max-width: 768px) {
    .autor-hero {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .autor-hero__photo-wrap {
    position: sticky;
    top: var(--space-8);
  }

  .autor-hero__photo {
    width: 100%;
    border: var(--border-thick);
    box-shadow: var(--shadow-lg);
    display: block;
  }

  .autor-hero__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .autor-hero__name {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    line-height: 1.1;
    margin-bottom: var(--space-2);
  }

  .autor-hero__title {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin-bottom: var(--space-6);
  }

  .autor-hero__summary {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-ink);
    margin-bottom: var(--space-8);
    padding: var(--space-4) var(--space-6);
    border-left: 5px solid var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 6%, var(--color-canvas));
  }

  /* ── Stats ─────────────────────────────────────────────────── */
  .autor-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .autor-stat {
    border: var(--border);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
    text-align: center;
  }

  .autor-stat__number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: var(--space-1);
  }

  .autor-stat__label {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  /* ── Corpo do artigo ────────────────────────────────────────── */
  .autor-body {
    max-width: 760px;
  }

  .autor-body h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 3px solid var(--color-accent);
  }

  .autor-body p {
    font-size: var(--text-base);
    line-height: 1.75;
    margin-bottom: var(--space-4);
    color: var(--color-ink);
  }

  .autor-body strong {
    font-weight: 700;
    color: var(--color-ink);
  }

  /* ── Credenciais ────────────────────────────────────────────── */
  .autor-credentials {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
    margin: var(--space-8) 0;
  }

  .autor-credential {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    border: var(--border);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
    background: var(--color-surface);
  }

  .autor-credential__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .autor-credential div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .autor-credential strong {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .autor-credential span {
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  /* ── FAQ ────────────────────────────────────────────────────── */
  .autor-faq {
    margin-top: var(--space-10);
    padding-top: var(--space-8);
    border-top: var(--border);
  }

  .faq-item {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 15%, transparent);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .faq-item p {
    line-height: 1.7;
    color: var(--color-ink);
  }

  /* ── CTA ────────────────────────────────────────────────────── */
  .autor-cta {
    margin-top: var(--space-10);
    padding: var(--space-8);
    border: var(--border-thick);
    box-shadow: var(--shadow);
    background: var(--color-accent);
    text-align: center;
  }

  .autor-cta p {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .autor-cta__btn {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    background: var(--color-ink);
    color: var(--color-surface);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    border: var(--border);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: box-shadow 0.15s, transform 0.15s;
