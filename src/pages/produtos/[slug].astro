---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { slugify } from '@utils/slugify';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const seenAsins = new Set<string>();
  const seenSlugs = new Set<string>();
  const paths: Array<{ params: { slug: string }; props: { produto: any; post: any } }> = [];

  for (const post of posts) {
    if (!post.data.produtos?.length) continue;
    for (const produto of post.data.produtos) {
      if (seenAsins.has(produto.asin)) continue;
      seenAsins.add(produto.asin);

      // Gera slug long-tail a partir do titulo; fallback com ASIN se colidir
      let slug = slugify(produto.titulo);
      if (seenSlugs.has(slug)) slug = `${slug}-${produto.asin.slice(-6).toLowerCase()}`;
      seenSlugs.add(slug);

      paths.push({ params: { slug }, props: { produto, post } });
    }
  }
  return paths;
}

const { produto, post } = Astro.props;

// --- helpers ---
function renderStars(r: number) {
  const filled = Math.round(r);
  return '★'.repeat(filled) + '☆'.repeat(5 - filled);
}
function fmtNum(n: number | null | undefined) {
  if (!n) return '0';
  return n.toLocaleString('pt-BR');
}
function fmtPrice(n: number | null | undefined) {
  if (!n) return null;
  return n.toFixed(2).replace('.', ',');
}

const titulo    = produto.titulo as string;
const asin      = produto.asin as string;
const imagem    = produto.imagem ?? null;
const preco     = fmtPrice(produto.preco);
const parcela   = produto.preco && produto.preco > 60 ? fmtPrice(produto.preco / 12) : null;
const rating    = produto.rating as number | null;
const ratingCount = produto.ratingCount as number | null;
const vendedor  = produto.vendedor || null;
const link      = produto.link as string;

const categoriaLabel: Record<string, string> = {
  suplementos:    'Suplementos',
  nutricao:       'Nutrição',
  treino:         'Treino',
  emagrecimento:  'Emagrecimento',
  saude:          'Saúde',
  'dicas-fit':    'Dicas Fit',
};
const catLabel = categoriaLabel[post.data.categoria] ?? 'Suplementos';

const { slug } = Astro.params;
const canonical = `https://melhoresreceitasfit.com.br/produtos/${slug}/`;
const imageUrl  = imagem ? `https://melhoresreceitasfit.com.br${imagem}` : undefined;

// SEO title: produto parte deve caber em 37 chars (+ " | Melhores Receitas Fit" = 60 total)
function makeSeoTitle(t: string, max = 37): string {
  if (t.length <= max) return t;
  const cut = t.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return lastSpace > max * 0.6 ? cut.slice(0, lastSpace) : cut;
}
const seoTitle = makeSeoTitle(titulo);

// Meta description: 80-155 chars
const shortName = makeSeoTitle(titulo, 40); // versao curta para a desc
const descParts: string[] = [shortName];
if (rating && ratingCount) {
  descParts.push(`— nota ${rating}/5 com ${fmtNum(ratingCount)} avaliacoes verificadas.`);
}
if (preco) {
  descParts.push(`Preco: R$ ${preco}.`);
}
descParts.push('Confira especificacoes completas e o melhor preco disponivel.');
let metaDescription = descParts.join(' ');
if (metaDescription.length < 80) {
  metaDescription += ' Entrega rapida em todo o Brasil.';
}
if (metaDescription.length > 155) {
  metaDescription = metaDescription.slice(0, 152) + '...';
}

// Sobre o produto — conteudo expandido por categoria
const conteudoPorCategoria: Record<string, { intro: string; beneficios: string[]; comoUsar: string; dica: string }> = {
  suplementos: {
    intro: `Os suplementos fitness são recursos amplamente utilizados por atletas e praticantes de atividade física para potencializar resultados, acelerar a recuperação muscular e complementar a alimentação do dia a dia. Quando combinados com treinos regulares e uma dieta equilibrada, esses produtos contribuem diretamente para o desempenho, a composição corporal e o bem-estar geral.`,
    beneficios: [
      'Suporte ao desempenho físico durante os treinos',
      'Auxílio na recuperação muscular pós-exercício',
      'Fórmula desenvolvida para praticantes de esportes',
      'Praticidade para complementar a ingestão de nutrientes',
      'Produto com avaliações verificadas por compradores reais',
    ],
    comoUsar: `Para melhores resultados, siga as orientações do fabricante indicadas na embalagem. Em geral, suplementos de performance são consumidos antes ou após os treinos, conforme o tipo e o objetivo. Consulte um nutricionista esportivo para adequar o uso à sua rotina alimentar e às suas metas.`,
    dica: `Antes de comprar, verifique a composição nutricional, o prazo de validade e a procedência do produto. Opte sempre por suplementos com registro na ANVISA e adquiridos de vendedores confiáveis.`,
  },
  nutricao: {
    intro: `Uma boa nutrição é a base para qualquer resultado na academia ou no esporte. Produtos voltados para a nutrição esportiva foram desenvolvidos para garantir o aporte adequado de macronutrientes — proteínas, carboidratos e gorduras saudáveis — além de micronutrientes essenciais para o funcionamento do organismo.`,
    beneficios: [
      'Contribui para o equilíbrio nutricional diário',
      'Ideal para complementar refeições em rotinas agitadas',
      'Fonte prática de nutrientes para atletas e esportistas',
      'Auxílio no controle do peso e na composição corporal',
      'Formulação desenvolvida com foco em qualidade nutricional',
    ],
    comoUsar: `Incorpore o produto na sua rotina alimentar conforme as recomendações do fabricante. Produtos de nutrição esportiva funcionam melhor quando integrados a uma dieta planejada e a um programa de treinos regular.`,
    dica: `Consulte um nutricionista para personalizar a sua estratégia alimentar. A suplementação é um complemento, não um substituto de uma alimentação variada e equilibrada.`,
  },
  treino: {
    intro: `Os equipamentos e acessórios de treino são fundamentais para quem busca evoluir com segurança, eficiência e conforto. Seja para aumentar a carga, melhorar a estabilidade ou proteger as articulações, contar com o material certo faz diferença nos resultados a longo prazo.`,
    beneficios: [
      'Melhora o desempenho e a segurança durante os exercícios',
      'Reduz o risco de lesões com suporte adequado',
      'Compatível com diversos tipos de treino e modalidades',
      'Material de qualidade para uso intensivo na academia ou em casa',
      'Produto avaliado positivamente por praticantes de esportes',
    ],
    comoUsar: `Utilize o produto conforme as instruções do fabricante. Para equipamentos de treino, respeite as capacidades de carga indicadas e faça manutenções periódicas para garantir durabilidade e segurança.`,
    dica: `Invista em equipamentos que se adaptem ao seu nível atual de treinamento e que permitam progressão. Um bom material é um investimento de longo prazo na sua saúde e performance.`,
  },
  emagrecimento: {
    intro: `Produtos voltados ao emagrecimento saudável têm como objetivo apoiar o déficit calórico, o controle do apetite ou o aumento do gasto energético, sempre como complemento a uma alimentação equilibrada e à prática regular de exercícios. A perda de peso sustentável é resultado de hábitos consistentes ao longo do tempo.`,
    beneficios: [
      'Suporte ao controle do peso corporal',
      'Auxílio no aumento da saciedade e controle do apetite',
      'Complemento a dietas com déficit calórico',
      'Formulado para uso em conjunto com exercícios físicos',
      'Produto com ingredientes selecionados e avaliações positivas',
    ],
    comoUsar: `Use o produto conforme as orientações da embalagem. Resultados consistentes dependem da combinação entre alimentação adequada, atividade física regular e sono de qualidade. Não substitua refeições sem orientação profissional.`,
    dica: `Consulte um médico ou nutricionista antes de iniciar qualquer protocolo de emagrecimento. A suplementação deve ser individualizada conforme saúde, objetivo e histórico do usuário.`,
  },
  saude: {
    intro: `Cuidar da saúde vai além dos treinos: vitaminas, minerais e outros suplementos de bem-estar são aliados importantes para manter o organismo funcionando de forma eficiente. Esses produtos ajudam a suprir deficiências nutricionais, fortalecer o sistema imunológico e promover a saúde em todas as fases da vida.`,
    beneficios: [
      'Suporte ao sistema imunológico e à saúde geral',
      'Complemento para suprir deficiências nutricionais',
      'Formulado com ingredientes respaldados pela ciência',
      'Indicado para adultos que buscam qualidade de vida',
      'Produto com boa procedência e avaliações verificadas',
    ],
    comoUsar: `Siga as instruções de dosagem indicadas pelo fabricante. Vitaminas lipossolúveis (A, D, E, K) devem ser consumidas com alimentos que contenham gordura para melhor absorção. Sempre consulte um profissional de saúde antes de iniciar qualquer suplementação.`,
    dica: `Prefira produtos com certificação de qualidade e registro na ANVISA. Exames de sangue periódicos ajudam a identificar deficiências reais e orientar a suplementação correta.`,
  },
  'dicas-fit': {
    intro: `Alcançar e manter um estilo de vida saudável exige não apenas disciplina nos treinos e na alimentação, mas também os produtos e estratégias certos para apoiar cada etapa da jornada. Seja para organizar a rotina, melhorar o sono, gerenciar o estresse ou otimizar a performance, há soluções desenvolvidas especificamente para quem vive o lifestyle fitness.`,
    beneficios: [
      'Apoio à rotina de saúde e bem-estar',
      'Produto alinhado ao estilo de vida ativo e saudável',
      'Solução prática para o dia a dia de atletas e esportistas',
      'Avaliado positivamente por usuários com objetivos similares',
      'Disponível com entrega rápida em todo o Brasil',
    ],
    comoUsar: `Use o produto conforme as recomendações do fabricante e integre-o à sua rotina de saúde. A consistência é o fator mais importante para obter resultados duradouros.`,
    dica: `Combine bons produtos com hábitos sólidos: sono adequado, hidratação, alimentação equilibrada e treinos progressivos. Pequenas melhorias constantes fazem grande diferença ao longo do tempo.`,
  },
};

const cat = post.data.categoria as string;
const ctd = conteudoPorCategoria[cat] ?? conteudoPorCategoria['suplementos'];

const descricaoLonga = [
  `${titulo}${vendedor ? `, produzido por ${vendedor},` : ''}`,
  rating && ratingCount
    ? ` é avaliado com nota ${rating}/5 por ${fmtNum(ratingCount)} compradores verificados.`
    : ' está disponível para compra online.',
  ' ' + ctd.intro,
  ` Clique em "Comprar Agora" para conferir o preço atualizado e a disponibilidade em estoque.`,
].join('');

// Schema
const productSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: titulo,
  image: imageUrl,
  description: metaDescription,
  ...(vendedor ? { brand: { '@type': 'Brand', name: vendedor } } : {}),
  offers: {
    '@type': 'Offer',
    ...(produto.preco != null ? { price: produto.preco } : {}),
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    url: link,
    ...(vendedor ? { seller: { '@type': 'Organization', name: vendedor } } : {}),
  },
  ...(rating && ratingCount
    ? {
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: rating,
          reviewCount: ratingCount,
          bestRating: 5,
          worstRating: 1,
        },
      }
    : {}),
};

const tituloShort = titulo.length > 50 ? titulo.slice(0, 50) + '...' : titulo;

const breadcrumbs = [
  { name: 'Home',       url: 'https://melhoresreceitasfit.com.br/' },
  { name: catLabel,     url: 'https://melhoresreceitasfit.com.br/blog/' },
  { name: tituloShort,  url: canonical },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<BaseLayout
  title={seoTitle}
  description={metaDescription}
  image={imagem}
  imageAlt={titulo}
  type="website"
  canonicalUrl={canonical}
  schema={[productSchema, breadcrumbSchema]}
>
  <Header />

  <main id="main-content">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />

      <!-- HERO -->
      <div class="produto-hero">

        <!-- Galeria -->
        <div class="produto-galeria">
          {imagem ? (
            <div class="produto-imagem-wrapper">
              <img
                src={imagem}
                alt={titulo}
                width="500"
                height="500"
                loading="eager"
                fetchpriority="high"
                decoding="sync"
                class="produto-imagem"
              />
            </div>
          ) : (
            <div class="produto-imagem-placeholder">
              <span>Imagem indisponivel</span>
            </div>
          )}

          {rating && (
            <div class="badge-avaliacao">
              <span class="badge-stars">{renderStars(rating)}</span>
              <span class="badge-num">{rating}/5</span>
            </div>
          )}
        </div>

        <!-- Detalhes -->
        <div class="produto-info">
          {vendedor && (
            <p class="produto-vendedor">
              Vendido por <strong>{vendedor}</strong>
            </p>
          )}

          <h1 class="produto-titulo">{titulo}</h1>

          {rating && (
            <div class="produto-rating">
              <span class="stars" aria-hidden="true">{renderStars(rating)}</span>
              <span class="rating-num">{rating}/5</span>
              {ratingCount && (
                <span class="rating-count">({fmtNum(ratingCount)} avaliacoes)</span>
              )}
            </div>
          )}

          <hr class="produto-divider" />

          {preco && (
            <div class="produto-preco-bloco">
              <div class="preco-principal">
                <span class="preco-currency">R$</span>
                <span class="preco-value">{preco}</span>
              </div>
              {parcela && (
                <p class="preco-parcelas">
                  ou 12x de <strong>R$ {parcela}</strong> sem juros
                </p>
              )}
            </div>
          )}

          <ul class="produto-disponibilidade">
            <li class="dispo-ok">Em estoque</li>
            <li class="dispo-ok">Entrega disponivel em todo o Brasil</li>
            <li class="dispo-ok">Produto com avaliacoes verificadas</li>
          </ul>

          <div class="produto-cta">
            <a
              href={link}
              target="_blank"
              rel="noopener sponsored"
              class="btn-comprar"
            >
              🛒 Comprar Agora
            </a>
            <a
              href={link}
              target="_blank"
              rel="noopener sponsored"
              class="btn-ver-preco"
            >
              Ver Melhor Preco
            </a>
          </div>

          <div class="trust-badges">
            <span>🔒 Compra segura</span>
            <span>📦 Envio rapido</span>
            <span>↩ Devolucao facilitada</span>
          </div>
        </div>
      </div>

      <!-- Sobre o Produto -->
      <section class="produto-secao">
        <h2>Sobre o Produto</h2>
        <p>{descricaoLonga}</p>
      </section>

      <!-- Beneficios -->
      <section class="produto-secao">
        <h2>Benefícios e Diferenciais</h2>
        <p>{ctd.intro}</p>
        <ul class="produto-beneficios-lista">
          {ctd.beneficios.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <!-- Como usar -->
      <section class="produto-secao">
        <h2>Como Usar</h2>
        <p>{ctd.comoUsar}</p>
      </section>

      <!-- Dica -->
      <section class="produto-secao produto-dica">
        <h2>Dica Importante</h2>
        <p>{ctd.dica}</p>
      </section>

      <!-- Informacoes tecnicas -->
      <section class="produto-secao">
        <h2>Informacoes do Produto</h2>
        <table class="specs-table">
          <tbody>
            {vendedor && (
              <tr><th>Vendedor</th><td>{vendedor}</td></tr>
            )}
            {rating && (
              <tr>
                <th>Avaliacao media</th>
                <td><span class="specs-stars">{renderStars(rating)}</span> {rating}/5</td>
              </tr>
            )}
            {ratingCount && (
              <tr><th>Total de avaliacoes</th><td>{fmtNum(ratingCount)}</td></tr>
            )}
            {produto.preco != null && (
              <tr><th>Preco</th><td>R$ {preco}</td></tr>
            )}
            <tr><th>Disponibilidade</th><td>Em estoque</td></tr>
            <tr><th>Categoria</th><td>{catLabel}</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Avaliacoes -->
      {rating && ratingCount && (
        <section class="produto-secao produto-avaliacoes">
          <h2>Avaliacoes dos Compradores</h2>
          <div class="rating-summary">
            <div class="rating-big-num">{rating}</div>
            <div class="rating-big-stars">{renderStars(rating)}</div>
            <div class="rating-big-label">{fmtNum(ratingCount)} avaliacoes verificadas</div>
          </div>
          <a href={link} target="_blank" rel="noopener sponsored" class="btn-avaliacoes">
            Ver todas as avaliacoes
          </a>
        </section>
      )}

      <!-- Link ao comparativo -->
      <section class="produto-comparativo">
        <p>Quer comparar este produto com outras opcoes da categoria?</p>
        <a href={`/blog/${post.slug}/`} class="link-comparativo">
          Ver Comparativo Completo &rarr;
        </a>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .produto-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-block: var(--space-6) var(--space-10);
  }

  @media (min-width: 768px) {
    .produto-hero {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
      gap: var(--space-12);
    }
  }

  /* ── Galeria ────────────────────────────────────────────── */
  @media (min-width: 768px) {
    .produto-galeria { position: sticky; top: var(--space-6); }
  }

  .produto-imagem-wrapper {
    border: var(--border-thick);
    box-shadow: var(--shadow);
    background: #fff;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .produto-imagem {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--space-6);
  }

  .produto-imagem-placeholder {
    border: var(--border-thick);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .badge-avaliacao {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: #fefce8;
    border: var(--border);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .badge-stars { color: #d97706; }

  /* ── Info ───────────────────────────────────────────────── */
  .produto-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .produto-vendedor {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
  }

  .produto-titulo {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    line-height: 1.25;
    margin: 0;
  }

  @media (max-width: 640px) {
    .produto-titulo { font-size: var(--text-lg); }
  }

  /* Rating */
  .produto-rating {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .stars { color: #d97706; font-size: var(--text-lg); letter-spacing: 0.03em; }
  .rating-num { font-weight: 700; font-size: var(--text-sm); }
  .rating-count { font-size: var(--text-sm); color: var(--color-muted); }

  .produto-divider { border: none; border-top: var(--border); margin: 0; }

  /* Preco */
  .produto-preco-bloco {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .preco-principal {
    display: flex;
    align-items: flex-start;
    gap: var(--space-1);
    line-height: 1;
  }

  .preco-currency {
    font-size: var(--text-xl);
    font-weight: 700;
    padding-top: 0.3em;
  }

  .preco-value {
    font-family: var(--font-display);
    font-size: var(--text-5xl, 3rem);
    font-weight: 900;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .preco-value { font-size: var(--text-3xl); }
  }

  .preco-parcelas {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
  }

  /* Disponibilidade */
  .produto-disponibilidade {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .dispo-ok {
    font-size: var(--text-sm);
    font-weight: 500;
    color: #16a34a;
  }

  .dispo-ok::before { content: '✓ '; }

  /* CTAs */
  .produto-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .btn-comprar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 1rem 1.5rem;
    background: var(--color-primary);
    color: #fff !important;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    text-align: center;
    text-decoration: none !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: var(--border-thick);
    box-shadow: var(--shadow);
    border-radius: var(--radius-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    cursor: pointer;
  }

  .btn-comprar:hover {
    box-shadow: var(--shadow-hover);
    transform: translate(-2px, -2px);
  }

  .btn-comprar:active {
    box-shadow: 2px 2px 0 #1a1a1a;
    transform: translate(3px, 3px);
  }

  .btn-ver-preco {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.5rem;
    background: var(--color-canvas);
    color: var(--color-ink) !important;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    text-align: center;
    text-decoration: none !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: var(--border-thick);
    box-shadow: 4px 4px 0 var(--color-ink);
    border-radius: var(--radius-sm);
    transition: box-shadow var(--transition), transform var(--transition);
  }

